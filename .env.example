# Copy to .env (or add these to /home/silidrone/silisoft/.env) and fill in:
DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=

# Optional overrides:
# ANTHROPIC_MODEL=claude-haiku-4-5   # use claude-sonnet-4-6 for smarter (slower) answers
# DEEPGRAM_MODEL=nova-3              # nova-3 (best) | nova-2 (cheaper). Default: nova-3
# KEYTERMS=Anthropic,Deepgram,Silisoft   # nova-3 only: bias transcription toward these terms
# LANGUAGE=en                        # Deepgram language, e.g. en, es, de, multi (multi = code-switching)
# INSIGHT_DEBOUNCE=3.0               # seconds of quiet before an auto-insight fires
# MIC_DEVICE=                        # override pactl default source
# SYSTEM_DEVICE=                     # override (default = default sink + ".monitor")
